{
  "enabledPlugins": {
    "ralph-skills@ralph-marketplace": true,
    "superpowers@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/run-eslint.sh",
            "async": true,
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/run-tscheck.sh",
            "async": true,
            "timeout": 10000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'notify --title \"Claude\" --message \"console 执行完毕\"' | nc -U /tmp/console.sock 2 > /dev/null"
          }
        ]
      }
    ]
  }
}
