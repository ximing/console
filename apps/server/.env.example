# Server Configuration
# Port number for the Express server (default: 3002)
PORT=3002

# Node environment: development, production, or test
NODE_ENV=development

# CORS Configuration
# Allowed origins for CORS (comma-separated)
CORS_ORIGIN=http://localhost:3002,http://localhost:5273

# MySQL Database Configuration
# MySQL host (default: localhost)
MYSQL_HOST=localhost

# MySQL port (default: 3306)
MYSQL_PORT=3306

# MySQL username
MYSQL_USER=root

# MySQL password
MYSQL_PASSWORD=

# MySQL database name
MYSQL_DATABASE=aimo

# Connection pool size (default: 10)
MYSQL_CONNECTION_LIMIT=10

# JWT Configuration
# Secret key for signing JWT tokens (REQUIRED - must be at least 32 characters)
# Generate a secure random string for production use
JWT_SECRET=your-jwt-secret-key-change-in-production-must-be-at-least-32-characters-long

# S3 configuration for avatar storage (Optional)
# Supports AWS S3 and MinIO-compatible storage
S3_BUCKET=avatars
S3_PREFIX=avatars
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# For MinIO set endpoint (e.g. http://localhost:9000); for AWS keep it empty
S3_ENDPOINT=http://localhost:9000

# For MinIO set true; for AWS usually false
S3_FORCE_PATH_STYLE=true

# MinIO Example for LanceDB S3-compatible storage (Optional)
# Uncomment and adjust when using MinIO for LanceDB
# LANCEDB_STORAGE_TYPE=s3
# LANCEDB_S3_BUCKET=aimo-lancedb
# LANCEDB_S3_PREFIX=lancedb
# LANCEDB_S3_ACCESS_KEY_ID=minioadmin
# LANCEDB_S3_SECRET_ACCESS_KEY=minioadmin
# LANCEDB_S3_REGION=us-east-1
# LANCEDB_S3_ENDPOINT=http://localhost:9000

# MinIO Example for attachment S3-compatible storage (Optional)
# Uncomment and adjust when using MinIO for attachments
# ATTACHMENT_STORAGE_TYPE=s3
# ATTACHMENT_S3_BUCKET=aimo-attachments
# ATTACHMENT_S3_PREFIX=attachments
# ATTACHMENT_S3_ACCESS_KEY_ID=minioadmin
# ATTACHMENT_S3_SECRET_ACCESS_KEY=minioadmin
# ATTACHMENT_S3_REGION=us-east-1
# ATTACHMENT_S3_ENDPOINT=http://localhost:9000
# ATTACHMENT_S3_IS_PUBLIC=false

# Redis Configuration
# Enable Redis (default: disabled)
REDIS_ENABLED=false

# Redis host (default: localhost)
REDIS_HOST=localhost

# Redis port (default: 6379)
REDIS_PORT=6379

# Redis password (optional, leave empty for no authentication)
REDIS_PASSWORD=

# Redis database number (0-15, default: 0)
REDIS_DB=0

# Key prefix for all Redis keys (default: aimo:)
REDIS_KEY_PREFIX=aimo:

# Connection timeout in ms (default: 10000)
REDIS_CONNECT_TIMEOUT=10000

# Max retries per request (default: 3)
REDIS_MAX_RETRIES=3
