    "urllib": "^2.44.0",
    "ws": "^8.20.0",
    "y-websocket": "^3.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.0",
    "@types/bcrypt": "^5.0.0",
    "@types/body-parser": "^1.19.6",
