    "@types/ws": "^8.18.1",
    "@x-console/dto": "workspace:*",
    "@x-console/logger": "workspace:*",
    "@y/websocket-server": "^0.1.5",
    "archiver": "^6.0.0",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.3",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csurf": "^1.11.0",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "express-jwt": "^8.5.1",
    "express-rate-limit": "^7.5.0",
    "express-ws": "^5.0.2",
    "glob": "^7.1.3",
    "helmet": "^8.1.0",
