{
  "name": "x-console",
  "version": "0.2.2",
  "private": true,
  "license": "BSL-1.1",
  "scripts": {
    "dev": "pnpm -r dev",
    "dev:web": "pnpm --filter @x-console/web dev",
    "dev:server": "pnpm --filter @x-console/server dev",
    "dev:client": "pnpm --filter @x-console/client dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @x-console/web build",
    "build:server": "pnpm --filter @x-console/server build",
    "build:client": "pnpm --filter @x-console/client build",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "prettier --write .",
    "rm": "find . -name \"node_modules\" -type d -prune -exec rm -rf '{}' +",
    "dev:env": "docker compose -f dev-docker-compose.yml up -d",
    "generate:icons": "bash scripts/generate-icons.sh"
  },
  "devDependencies": {
    "@changesets/cli": "^2.28.0",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@types/node": "^20.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^9.1.7",
    "plop": "^4.0.1",
    "prettier": "^3.5.1",
    "rollup": "^4.12.0",
    "tsx": "^4.19.2",
    "turbo": "^2.4.2",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@10.22.0"
}
